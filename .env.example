# ============================================================
# PresupuestoGo — Variables de entorno
# Copia este archivo como .env.local y rellena tus valores
# NUNCA subas .env.local a GitHub
# ============================================================

# Supabase — obtenlos en https://supabase.com > tu proyecto > Settings > API
VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# App
VITE_APP_NAME=PresupuestoGo
VITE_APP_URL=https://presupuestogo.cr

# Tipo de cambio BCCR (opcional — se puede dejar vacío al inicio)
VITE_BCCR_TOKEN=
